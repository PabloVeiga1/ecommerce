generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model produto {
  id        Int     @id @default(autoincrement())
  nome      String  @db.VarChar(100)
  descricao String?
  preco     Decimal @db.Decimal(10, 2)
  estoque   Int
  imagem    String? @db.VarChar(255)
}
